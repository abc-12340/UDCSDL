-- 1. TAO CO SO DU LIEU
CREATE DATABASE QuanLyNhaThuoc;
GO

USE QuanLyNhaThuoc;
GO

-- 2. TAO BANG
-- Bang NHAN VIEN
CREATE TABLE NHAN_VIEN(
	IDNhanVien			INT	IDENTITY(1,1),
	HoTen				NVARCHAR(100) NOT NULL,
	GioiTinh			NVARCHAR(10) NOT NULL,
	NgaySinh			DATE,
	DienThoai			CHAR(10) NOT NULL,
	Email				VARCHAR(100),
	DiaChi				NVARCHAR(200) NOT NULL,
	NgayVaoLam			DATE DEFAULT CONVERT(DATE, GETDATE()),
    GhiChu				NVARCHAR(200),

    CONSTRAINT PK_NHAN_VIEN PRIMARY KEY (IDNhanVien),
    CONSTRAINT UQ_NV_SDT UNIQUE (DienThoai),
	CONSTRAINT CK_NV_GioiTinh CHECK (GioiTinh IN (N'Nam', N'Nữ'))
);
GO

-- Bang NHA CUNG CAP
CREATE TABLE NHA_CUNG_CAP(
	IDNhaCungCap		INT IDENTITY(1,1),
	TenNhaCungCap		NVARCHAR(100) NOT NULL,
	DiaChi				NVARCHAR(200) NOT NULL,
	DienThoai			CHAR(10) NOT NULL,
	Email				VARCHAR(100),
    GhiChu				NVARCHAR(200),

    CONSTRAINT PK_NHA_CUNG_CAP PRIMARY KEY (IDNhaCungCap),
	CONSTRAINT UQ_NCC_SDT UNIQUE (DienThoai)
);
GO

-- Bang KHACH HANG
CREATE TABLE KHACH_HANG(
	IDKhachHang			INT IDENTITY(1,1),
	HoTen				NVARCHAR(100) NOT NULL,
	GioiTinh			NVARCHAR(10) NOT NULL,
	NgaySinh			DATE,
	DienThoai			CHAR(10) NOT NULL,
    GhiChu				NVARCHAR(200),

    CONSTRAINT PK_KHACH_HANG PRIMARY KEY (IDKhachHang),
	CONSTRAINT UQ_KH_SDT UNIQUE (DienThoai),
	CONSTRAINT CK_KH_GioiTinh CHECK (GioiTinh IN (N'Nam', N'Nữ'))
);
GO

-- Bang NHOM THUOC
CREATE TABLE NHOM_THUOC(
	IDNhomThuoc			INT IDENTITY(1,1),
	TenNhom				NVARCHAR(100) NOT NULL,
	MoTa				NVARCHAR(200),
    GhiChu				NVARCHAR(200),

    CONSTRAINT PK_NHOM_THUOC PRIMARY KEY (IDNhomThuoc)
);
GO

-- Bang THUOC
CREATE TABLE THUOC(
	IDThuoc				INT IDENTITY(1,1),
    IDNhomThuoc			INT NOT NULL,
	TenThuoc			NVARCHAR(100) NOT NULL,
	TenHoatChat			NVARCHAR(100) NOT NULL,
	HamLuong			NVARCHAR(50) NOT NULL,
	DangBaoChe			NVARCHAR(50) NOT NULL,
	DonViTinh			NVARCHAR(50) NOT NULL,
    NuocSanXuat			NVARCHAR(50),
    GhiChu				NVARCHAR(200),

    CONSTRAINT PK_THUOC PRIMARY KEY (IDThuoc),
	CONSTRAINT FK_THUOC_NHOM FOREIGN KEY (IDNhomThuoc) REFERENCES NHOM_THUOC(IDNhomThuoc)
);
GO

-- Bang LO HANG
CREATE TABLE LO_HANG(
	IDLoHang			INT IDENTITY(1,1),
	IDThuoc				INT NOT NULL,
	SoLoNCC				VARCHAR(50) NOT NULL,
	NgaySanXuat			DATE NOT NULL,
	NgayHetHan			DATE NOT NULL,
	NgayNhap			DATE NOT NULL DEFAULT CONVERT(DATE,GETDATE()),
	SoLuongNhap			INT NOT NULL,
	DonViTinh			NVARCHAR(50) NOT NULL,
	DonGiaNhap			INT NOT NULL, 
	DonGiaBan			INT NOT NULL, 
	IDNvNhap			INT NOT NULL,
	IDNhaCungCap		INT NOT NULL,
	SoLuongTon			INT NOT NULL,
    GhiChu				NVARCHAR(200),

    CONSTRAINT PK_LO_HANG PRIMARY KEY (IDLoHang),
	CONSTRAINT FK_LO_THUOC FOREIGN KEY (IDThuoc) REFERENCES THUOC(IDThuoc),
	CONSTRAINT FK_LO_NV FOREIGN KEY (IDNvNhap) REFERENCES NHAN_VIEN(IDNhanVien),
	CONSTRAINT FK_LO_NCC FOREIGN KEY (IDNhaCungCap) REFERENCES NHA_CUNG_CAP(IDNhaCungCap),
	CONSTRAINT CK_LO_Ngay CHECK (NgayHetHan > NgayNhap AND NgayNhap > NgaySanXuat),
	CONSTRAINT CK_LO_SoLuong CHECK (SoLuongNhap > 0 AND SoLuongTon <= SoLuongNhap),
	CONSTRAINT CK_LO_Gia CHECK (DonGiaNhap > 0 AND DonGiaBan > 0)
);
GO

-- Bang HOA DON
CREATE TABLE HOA_DON(
	IDHoaDon			INT IDENTITY(1,1),
	IDKhachHang			INT NOT NULL,
	IDNhanVien			INT NOT NULL,
	NgayLap				DATETIME NOT NULL DEFAULT GETDATE(),
	TongTien			INT NOT NULL,
	HinhThucThanhToan	NVARCHAR(50) NOT NULL,
    GhiChu				NVARCHAR(200),

    CONSTRAINT PK_HOA_DON PRIMARY KEY (IDHoaDon),
	CONSTRAINT FK_HD_KH FOREIGN KEY (IDKhachHang) REFERENCES KHACH_HANG(IDKhachHang),
	CONSTRAINT FK_HD_NV FOREIGN KEY (IDNhanVien) REFERENCES NHAN_VIEN(IDNhanVien),
	CONSTRAINT CK_HD_Httt CHECK (HinhThucThanhToan IN (N'Tiền mặt', N'Chuyển khoản')),
);
GO

-- Bang CHI TIET HOA DON
CREATE TABLE CHI_TIET_HOA_DON(
	IDHoaDon			INT NOT NULL,
	IDThuoc				INT NOT NULL,
	SoLuong				INT NOT NULL,
	DonGia				INT NOT NULL,
	ThanhTien			AS (SoLuong * DonGia) PERSISTED,
    GhiChu				NVARCHAR(200),

    CONSTRAINT PK_CT_HOA_DON PRIMARY KEY (IDHoaDon, IDThuoc),
	CONSTRAINT FK_CTHD_HD FOREIGN KEY (IDHoaDon) REFERENCES HOA_DON(IDHoaDon),
    CONSTRAINT FK_CTHD_THUOC FOREIGN KEY (IDThuoc) REFERENCES THUOC(IDThuoc),
	CONSTRAINT CK_CTHD CHECK (SoLuong > 0 AND DonGia > 0)
);
GO


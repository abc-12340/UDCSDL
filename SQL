-- 1. TAO CO SO DU LIEU
CREATE DATABASE QuanLyNhaThuoc;
GO

USE QuanLyNhaThuoc;
GO

-- 2. TAO BANG
-- Bang NHAN VIEN
CREATE TABLE NHAN_VIEN(
	IDNhanVien INT IDENTITY(1,1),
	HoTen NVARCHAR(100) NOT NULL,
	GioiTinh NVARCHAR(10) NOT NULL,
	NgaySinh DATE,
	DienThoai NVARCHAR(10) NOT NULL,
	Email NVARCHAR(100),
	DiaChi NVARCHAR(200) NOT NULL,
  ChucVu NVARCHAR(20) NOT NULL,
	NgayVaoLam DATE DEFAULT CONVERT(DATE, GETDATE()),
	TrangThai BIT NOT NULL,
  GhiChu NVARCHAR(200),

  CONSTRAINT PK_NHAN_VIEN PRIMARY KEY (IDNhanVien),
  CONSTRAINT UQ_NV_SDT UNIQUE (DienThoai),
	CONSTRAINT CK_NV_GioiTinh CHECK (GioiTinh IN (N'Nam', N'Nữ'))
);

-- Bang TAI KHOAN
CREATE TABLE TAI_KHOAN(
	IDTaiKhoan INT IDENTITY(1,1),
	TenDangNhap NVARCHAR(50) NOT NULL,
	MatKhau NVARCHAR(100) NOT NULL,
	QuyenHan NVARCHAR(20) NOT NULL,
	IDNhanVien INT NOT NULL,
	NgayTao DATETIME NOT NULL DEFAULT GETDATE(),
	TrangThai BIT NOT NULL,
  GhiChu NVARCHAR(200),

  CONSTRAINT PK_TAI_KHOAN PRIMARY KEY (IDTaiKhoan),
  CONSTRAINT FK_TK_NV FOREIGN KEY (IDNhanVien) REFERENCES NHAN_VIEN(IDNhanVien),
  CONSTRAINT UQ_TK_DN UNIQUE (TenDangNhap),
	CONSTRAINT UQ_TK_NV UNIQUE (IDNhanVien)
);

-- Bang NHA CUNG CAP
CREATE TABLE NHA_CUNG_CAP(
	IDNhaCungCap INT IDENTITY(1,1),
	TenNhaCungCap NVARCHAR(100) NOT NULL,
	DiaChi NVARCHAR(200) NOT NULL,
	DienThoai NVARCHAR(10) NOT NULL,
	Email NVARCHAR(100),
  TrangThai BIT NOT NULL,
  GhiChu NVARCHAR(200),

  CONSTRAINT PK_NHA_CUNG_CAP PRIMARY KEY (IDNhaCungCap),
	CONSTRAINT UQ_NCC_SDT UNIQUE (DienThoai)
);

-- Bang KHACH HANG
CREATE TABLE KHACH_HANG(
	IDKhachHang INT IDENTITY(1,1),
	HoTen NVARCHAR(100) NOT NULL,
	GioiTinh NVARCHAR(10) NOT NULL,
	NgaySinh DATE,
	DienThoai NVARCHAR(10),
	Email NVARCHAR(100),
	DiaChi NVARCHAR(200),
	NgayTao DATE NOT NULL DEFAULT CONVERT(DATE,GETDATE()),
  GhiChu NVARCHAR(200),

  CONSTRAINT PK_KHACH_HANG PRIMARY KEY (IDKhachHang),
	CONSTRAINT UQ_KH_SDT UNIQUE (DienThoai),
	CONSTRAINT CK_KH_GioiTinh CHECK (GioiTinh IN (N'Nam', N'Nữ'))
);

-- Bang NHOM THUOC
CREATE TABLE NHOM_THUOC(
	IDNhomThuoc INT IDENTITY(1,1),
	TenNhom NVARCHAR(100) NOT NULL,
	MoTa NVARCHAR(200),
	TrangThai BIT NOT NULL,
  GhiChu NVARCHAR(200),

  CONSTRAINT PK_NHOM_THUOC PRIMARY KEY (IDNhomThuoc)
);

-- Bang THUOC
CREATE TABLE THUOC(
	IDThuoc INT IDENTITY(1,1),
  IDNhomThuoc INT NOT NULL,
	TenThuoc NVARCHAR(100) NOT NULL,
	TenHoatChat NVARCHAR(100) NOT NULL,
	HamLuong NVARCHAR(50) NOT NULL,
	DangBaoChe NVARCHAR(50) NOT NULL,
	DonViTinh NVARCHAR(50) NOT NULL,
  NhaSanXuat NVARCHAR(100),
  NuocSanXuat NVARCHAR(50),
  TrangThai BIT NOT NULL,
  GhiChu NVARCHAR(200),

  CONSTRAINT PK_THUOC PRIMARY KEY (IDThuoc),
	CONSTRAINT FK_THUOC_NHOM FOREIGN KEY (IDNhomThuoc) REFERENCES NHOM_THUOC(IDNhomThuoc)
);

-- Bang LO HANG
CREATE TABLE LO_HANG(
	IDLoHang INT IDENTITY(1,1),
	IDThuoc INT NOT NULL,
	SoLoNCC NVARCHAR(50) NOT NULL,
	NgaySanXuat DATE NOT NULL,
	NgayHetHan DATE NOT NULL,
	NgayNhap DATE NOT NULL DEFAULT CONVERT(DATE,GETDATE()),
	SoLuongNhap INT NOT NULL,
	GiaNhap DECIMAL(18, 2) NOT NULL,
	IDNvNhap INT NOT NULL,
	GiaBan DECIMAL(18, 2) NOT NULL,
	IDNhaCungCap INT NOT NULL,
	SoLuongTon INT NOT NULL, -- em mới thêm vào hihihihi
  TrangThai BIT NOT NULL,
  GhiChu NVARCHAR(200),

  CONSTRAINT PK_LO_HANG PRIMARY KEY (IDLoHang),
	CONSTRAINT FK_LO_THUOC FOREIGN KEY (IDThuoc) REFERENCES THUOC(IDThuoc),
	CONSTRAINT FK_LO_NV FOREIGN KEY (IDNvNhap) REFERENCES NHAN_VIEN(IDNhanVien),
	CONSTRAINT FK_LO_NCC FOREIGN KEY (IDNhaCungCap) REFERENCES NHA_CUNG_CAP(IDNhaCungCap),
	CONSTRAINT CK_LO_NGAY CHECK (NgayHetHan > NgayNhap AND NgayNhap > NgaySanXuat),
	CONSTRAINT CK_LO_SOLUONG CHECK (SoLuongNhap > 0 AND SoLuongTon <= SoLuongNhap),
	CONSTRAINT CK_LO_GIA CHECK (GiaNhap > 0 AND GiaBan > 0)
);

-- Bang MA GIAM GIA
CREATE TABLE MA_GIAM_GIA(
	IDGiamGia INT IDENTITY(1,1),
	TenChuongTrinh NVARCHAR(100) NOT NULL,
	LoaiGiam NVARCHAR(10) NOT NULL ,
	GiaTriGiam DECIMAL(18, 2) NOT NULL ,
	DieuKienApDung NVARCHAR(200),
	NgayBatDau DATE NOT NULL,
	NgayKetThuc DATE NOT NULL,
	SoLanSuDungToiDa INT, -- nếu có cnay thì kiểm soát số lượng đã dùng nnao
  TrangThai BIT NOT NULL,
  GhiChu NVARCHAR(200),

  CONSTRAINT PK_MA_GIAM_GIA PRIMARY KEY (IDGiamGia),
  CONSTRAINT CK_MGG_LOAI CHECK (LoaiGiam IN (N'%', N'VND')),
  CONSTRAINT CK_MGG_GT CHECK (GiaTriGiam > 0),
  CONSTRAINT CK_MGG_NGAY CHECK (NgayKetThuc > NgayBatDau)
);

-- Bang HOA DON
CREATE TABLE HOA_DON(
	IDHoaDon INT IDENTITY(1,1),
	IDKhachHang INT NOT NULL,
	IDNhanVien INT NOT NULL,
	IDGiamGia INT,
	NgayLap DATETIME NOT NULL DEFAULT GETDATE(),
	TongTien DECIMAL(18, 2) NOT NULL,
	GiamGia DECIMAL(18, 2) DEFAULT 0,
	ThanhToan AS (TongTien - GiamGia) PERSISTED,
	HinhThucThanhToan NVARCHAR(50),
	TichDiem INT,
  DaCongDiem BIT NULL,
	NgayTichDiem DATETIME,
	TrangThai NVARCHAR(30), -- CÓ CẦN KO KIỂU (ĐÃ THANH TOÁN/ ĐÃ HỦY)
  GhiChu NVARCHAR(200),

  CONSTRAINT PK_HOA_DON PRIMARY KEY (IDHoaDon),
	CONSTRAINT FK_HD_KH FOREIGN KEY (IDKhachHang) REFERENCES KHACH_HANG(IDKhachHang),
	CONSTRAINT FK_HD_NV FOREIGN KEY (IDNhanVien) REFERENCES NHAN_VIEN(IDNhanVien),
	CONSTRAINT FK_HD_GG FOREIGN KEY (IDGiamGia) REFERENCES MA_GIAM_GIA(IDGiamGia),
	CONSTRAINT CK_HD_TIEN CHECK (TongTien >= 0 AND GiamGia <= TongTien)
);

-- Bang CHI TIET HOA DON
CREATE TABLE CHI_TIET_HOA_DON(
	IDHoaDon INT NOT NULL,
	IDThuoc INT NOT NULL, -- THÊM LÔ HÀNG TỰ ĐỘNG ĐỂ LƯU THÔNG TIN, TRUY VẾT KHI CẦN
  TenThuoc NVARCHAR(200) NOT NULL,
	IDLoHang INT NOT NULL,
	SoLuong INT NOT NULL,
	DonGia DECIMAL(18, 2) NOT NULL, --XEM CÓ INT KO
	ThanhTien AS (SoLuong * DonGia) PERSISTED,
  GhiChu NVARCHAR(200),

  CONSTRAINT PK_CT_HOA_DON PRIMARY KEY (IDHoaDon, IDThuoc),
	CONSTRAINT FK_CTHD_HD FOREIGN KEY (IDHoaDon) REFERENCES HOA_DON(IDHoaDon),
  CONSTRAINT FK_CTHD_THUOC FOREIGN KEY (IDThuoc) REFERENCES THUOC(IDThuoc),
	CONSTRAINT FK_CTHD_LO FOREIGN KEY (IDLoHang) REFERENCES LO_HANG(IDLoHang),
	CONSTRAINT CK_CTHD CHECK (SoLuong > 0 AND DonGia > 0)
);

-- Bang LICH SU TICH DIEM
CREATE TABLE LICH_SU_TICH_DIEM( 
	IDKhachHang INT NOT NULL,
	IDHoaDon INT NOT NULL,
	NgayGiaoDich DATETIME NOT NULL DEFAULT GETDATE(),
	DiemCong INT NOT NULL DEFAULT 0,
  DiemTru INT NOT NULL DEFAULT 0,
  LiDo NVARCHAR(50),
  GhiChu NVARCHAR(200),

  CONSTRAINT PK_LS_TICH_DIEM PRIMARY KEY (IDKhachHang, NgayGiaoDich),
  CONSTRAINT FK_LSTD_KH FOREIGN KEY (IDKhachHang) REFERENCES KHACH_HANG(IDKhachHang),
  CONSTRAINT FK_LSTD_HD FOREIGN KEY (IDHoaDon) REFERENCES HOA_DON(IDHoaDon),
	CONSTRAINT CK_LSTD_DIEM CHECK ((DiemCong > 0 AND DiemTru = 0) OR (DiemTru > 0 AND DiemCong = 0))
);

-- Bang TICH LUY KHACH HANG
CREATE TABLE TICH_LUY_KHACH_HANG(
	IDKhachHang INT NOT NULL,
	TongDiemTichLuy INT NOT NULL,
	NgayCapNhat DATETIME NOT NULL DEFAULT GETDATE(),
	GhiChu NVARCHAR(200),

  CONSTRAINT PK_TL_KHACH_HANG PRIMARY KEY (IDKhachHang),
  CONSTRAINT FK_TLKH_KH FOREIGN KEY (IDKhachHang) REFERENCES KHACH_HANG(IDKhachHang),
  CONSTRAINT CK_TLKH CHECK (TongDiemTichLuy >= 0)
);
